rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(email) {
      return request.auth != null && request.auth.token.email == email;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "dsimpsonj@gmail.com";
    }

    match /users/{email} {
      allow read, write: if isOwner(email) || request.auth == null;

      match /momentum/{date} {
        allow read, write: if isOwner(email) || request.auth == null;
      }
match /coachingProfile/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /weeklyCalibrations/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }
      match /weeklySummaries/{weekId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /metadata/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /profile/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /weightHistory/{entryId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /checkins/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /weeklyStats/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /insights/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }

      match /sessions/{docId} {
        allow read, write: if isOwner(email) || request.auth == null;
      }
    }

    match /articles/{articleId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}